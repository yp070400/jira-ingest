# =============================================================================
# JIRA Resolution Intelligence Tool — Environment Configuration
# Copy this file to .env.dev for local development
# =============================================================================

# Application
APP_ENV=development
APP_NAME="JIRA Resolution Intelligence"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=DEBUG

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# Security
SECRET_KEY=change-me-in-production-must-be-32-chars-min
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Database
DATABASE_URL=postgresql+asyncpg://jira_user:jira_pass@localhost:5432/jira_intel
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=20

# FAISS Vector Store
FAISS_INDEX_PATH=/app/data/faiss
FAISS_INDEX_DIMENSION=1536
FAISS_SIMILARITY_THRESHOLD=0.70
NOVELTY_THRESHOLD=0.40

# Embedding Configuration
# Options: mock | openai | sentence_transformer
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-ada-002
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=32

# LLM Configuration
# Options: mock | openai | anthropic
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

# OpenAI (if using openai provider)
OPENAI_API_KEY=sk-your-openai-key

# Anthropic (if using anthropic provider)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# JIRA Configuration
# Options: mock | real
JIRA_ADAPTER=mock
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEYS=PROJ,INFRA,PLATFORM
JIRA_SYNC_INTERVAL_MINUTES=30
JIRA_MAX_RESULTS_PER_PAGE=100
JIRA_RESOLVED_STATUSES=Done,Resolved,Closed

# Analysis Configuration
QUICK_ANALYSIS_TOP_K=5
DEEP_ANALYSIS_TOP_K=10
QUICK_CACHE_TTL=1800
CONFIDENCE_REVIEW_THRESHOLD=0.60
CRITICAL_KEYWORDS=production,outage,data-loss,security,breach,critical

# Feedback & Reranking
FEEDBACK_MIN_SAMPLES=10
FEEDBACK_DECAY_LAMBDA=0.1
RERANKING_SIMILARITY_WEIGHT=1.0
RERANKING_RECENCY_WEIGHT=0.2
RERANKING_FEEDBACK_WEIGHT=0.3
RERANKING_QUALITY_WEIGHT=0.2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEEP_REQUESTS=10
RATE_LIMIT_DEEP_WINDOW_SECONDS=60

# Background Jobs
INGESTION_CRON=*/30 * * * *
FEEDBACK_AGGREGATION_CRON=0 2 * * *
EMBEDDING_HEALTH_CRON=0 * * * *

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true