# =============================================================================
# Local Development Environment — DO NOT COMMIT PRODUCTION SECRETS
# =============================================================================

APP_ENV=development
APP_NAME="JIRA Resolution Intelligence"
APP_VERSION="1.0.0"
DEBUG=true
LOG_LEVEL=DEBUG

HOST=0.0.0.0
PORT=8000
WORKERS=1

SECRET_KEY=dev-secret-key-change-this-in-prod-32chars
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

DATABASE_URL=postgresql+asyncpg://jira_user:jira_pass@postgres:5432/jira_intel
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30

REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600
REDIS_MAX_CONNECTIONS=10

FAISS_INDEX_PATH=/app/data/faiss
FAISS_INDEX_DIMENSION=384
FAISS_SIMILARITY_THRESHOLD=0.70
NOVELTY_THRESHOLD=0.40

EMBEDDING_PROVIDER=sentence_transformer
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32

# LLM is used only for generating the fix_summary / step_by_step_fix text.
# Keep mock for private networks (no OpenAI/Anthropic access).
# Switch to openai or anthropic only if you have internet access to those APIs.
LLM_PROVIDER=mock
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.2

OPENAI_API_KEY=sk-placeholder
ANTHROPIC_API_KEY=sk-ant-placeholder

JIRA_ADAPTER=real
# Self-hosted Server/DC: include the context path in the URL
JIRA_BASE_URL=https://dbatlas.db.com/jira02
# 2 = Server/Data Center  |  3 = Atlassian Cloud
JIRA_API_VERSION=2
JIRA_USERNAME=your.email@company.com
# Use your JIRA password, or a Personal Access Token if your instance supports it
JIRA_API_TOKEN=your-password-or-pat
JIRA_PROJECT_KEYS=CBHVPEMEA
JIRA_SYNC_INTERVAL_MINUTES=30
JIRA_MAX_RESULTS_PER_PAGE=50
JIRA_RESOLVED_STATUSES=Done,Resolved,Closed,Fixed

QUICK_ANALYSIS_TOP_K=5
DEEP_ANALYSIS_TOP_K=10
QUICK_CACHE_TTL=1800
CONFIDENCE_REVIEW_THRESHOLD=0.60
CRITICAL_KEYWORDS=production,outage,data-loss,security,breach,critical

FEEDBACK_MIN_SAMPLES=5
FEEDBACK_DECAY_LAMBDA=0.1
RERANKING_SIMILARITY_WEIGHT=1.0
RERANKING_RECENCY_WEIGHT=0.2
RERANKING_FEEDBACK_WEIGHT=0.3
RERANKING_QUALITY_WEIGHT=0.2

RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEEP_REQUESTS=50
RATE_LIMIT_DEEP_WINDOW_SECONDS=60

INGESTION_CRON=*/5 * * * *
FEEDBACK_AGGREGATION_CRON=0 2 * * *
EMBEDDING_HEALTH_CRON=0 * * * *

CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true